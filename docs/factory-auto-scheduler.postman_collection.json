                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Assembly\"\n}" },
            "url": { "raw": "{{baseUrl}}/skills", "host": ["{{baseUrl}}"], "path": ["skills"] }
          }
        },
        {
          "name": "Update Employee — empty name → 400",
          "description": "`name` is optional in a PATCH request, but if provided it must be a non-empty string. Sending `\"name\": \"\"` returns `400 Bad Request`.\n\n> **Prerequisite:** run *Create Employee* first so `{{employeeId}}` is set.",
          "event": [
            {
              "listen": "test",
